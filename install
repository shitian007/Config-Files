#!/bin/bash

# Install script for Config-Files
# Usage: ./install vim

if [ $# -ne 1 ]; then
    echo "Usage: $0 <component>"
    echo "  vim - Install Vim RC file with Vundle and plugins"
    echo "  zsh - Install Zsh and Oh My Zsh"
    exit 1
fi

COMPONENT=$1
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

case "$COMPONENT" in
    vim)
        echo "Installing Vim dependencies..."
        
        # Install Vundle
        VUNDLE_DIR="$HOME/.vim/bundle/Vundle.vim"
        if [ ! -d "$VUNDLE_DIR" ]; then
            echo "Installing Vundle plugin manager..."
            mkdir -p "$HOME/.vim/bundle"
            git clone https://github.com/VundleVim/Vundle.vim.git "$VUNDLE_DIR"
            if [ $? -eq 0 ]; then
                echo "✓ Vundle installed to $VUNDLE_DIR"
            else
                echo "✗ Error: Failed to install Vundle"
                exit 1
            fi
        else
            echo "✓ Vundle already installed"
        fi
        
        # Install Vim RC file
        echo "Installing Vim RC file..."
        if [ -f "$SCRIPT_DIR/.vimrc" ]; then
            cp "$SCRIPT_DIR/.vimrc" ~/.vimrc
            echo "✓ Vim RC file installed to ~/.vimrc"
        else
            echo "✗ Error: .vimrc file not found in repository"
            exit 1
        fi
        
        # Install plugins via Vundle
        echo "Installing Vim plugins (this may take a moment)..."
        vim +PluginInstall +qall
        if [ $? -eq 0 ]; then
            echo "✓ Vim plugins installed successfully"
        else
            echo "⚠ Warning: Vim plugin installation completed with warnings (see above)"
        fi
        ;;
    zsh)
        echo "Installing Zsh and Oh My Zsh..."
        
        # Check if zsh is installed, if not install it
        if ! command -v zsh &> /dev/null; then
            echo "Installing Zsh..."
            if command -v apt-get &> /dev/null; then
                sudo apt-get update && sudo apt-get install -y zsh
            elif command -v brew &> /dev/null; then
                brew install zsh
            elif command -v yum &> /dev/null; then
                sudo yum install -y zsh
            else
                echo "✗ Error: Could not determine package manager to install Zsh"
                exit 1
            fi
            if [ $? -eq 0 ]; then
                echo "✓ Zsh installed successfully"
            else
                echo "✗ Error: Failed to install Zsh"
                exit 1
            fi
        else
            echo "✓ Zsh is already installed"
        fi
        
        # Install Oh My Zsh
        OMZ_DIR="$HOME/.oh-my-zsh"
        if [ ! -d "$OMZ_DIR" ]; then
            echo "Installing Oh My Zsh..."
            sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
            if [ $? -eq 0 ]; then
                echo "✓ Oh My Zsh installed to $OMZ_DIR"
            else
                echo "✗ Error: Failed to install Oh My Zsh"
                exit 1
            fi
        else
            echo "✓ Oh My Zsh is already installed"
        fi
        
        echo "✓ Zsh setup complete!"
        echo "Note: You may need to restart your terminal or run 'exec zsh' to switch shells"
        ;;
    *)
        echo "Error: Unknown component '$COMPONENT'"
        echo "Supported components: vim, zsh"
        exit 1
        ;;
esac
